# Trade M8 - Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# CLOUDFLARE CONFIGURATION
# ============================================================================
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ============================================================================
# EXCHANGE API KEYS - DEX (Decentralized Exchanges)
# ============================================================================

# Ethereum/EVM RPC Endpoints
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# Wallet Private Keys (NEVER commit these!)
# Use a dedicated trading wallet with limited funds
TRADING_WALLET_PRIVATE_KEY=0x_your_private_key_here_KEEP_SECRET

# Uniswap V3 Configuration
UNISWAP_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564
UNISWAP_QUOTER_ADDRESS=0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6

# PancakeSwap Configuration
PANCAKESWAP_ROUTER_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E

# SushiSwap Configuration
SUSHISWAP_ROUTER_ADDRESS=0xd9e1cE17f2641f24aE83637ab66a2cca9C378B9F

# ============================================================================
# EXCHANGE API KEYS - CEX (Centralized Exchanges)
# ============================================================================

# Binance API Configuration
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true  # Set to false for production
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret_key

# Coinbase API Configuration
# Get from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here
COINBASE_SANDBOX=true  # Set to false for production

# Kraken API Configuration
# Get from: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_PRIVATE_KEY=your_kraken_private_key_here

# ============================================================================
# MARKET DATA APIS
# ============================================================================

# CoinGecko API (for price data, market cap, etc.)
# Free tier: 10-50 calls/minute
# Pro: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=your_coingecko_api_key_here
COINGECKO_PRO=false

# Alternative Market Data APIs
CRYPTOCOMPARE_API_KEY=your_cryptocompare_key
MESSARI_API_KEY=your_messari_key

# ============================================================================
# AI & SENTIMENT ANALYSIS
# ============================================================================

# OpenAI API (for advanced AI analysis)
OPENAI_API_KEY=your_openai_api_key_here

# News APIs for sentiment analysis
NEWS_API_KEY=your_newsapi_key_here
CRYPTOPANIC_API_KEY=your_cryptopanic_key

# Twitter/X API (for social sentiment)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# ============================================================================
# DATABASE & STORAGE
# ============================================================================

# D1 Database (Cloudflare)
D1_DATABASE_ID=your_d1_database_id
D1_DATABASE_NAME=xq-trade-m8-db

# KV Namespaces (Cloudflare)
KV_CACHE_ID=your_kv_cache_namespace_id
KV_SESSIONS_ID=your_kv_sessions_namespace_id
KV_TRADES_ID=your_kv_trades_namespace_id

# R2 Storage (Cloudflare)
R2_BUCKET_NAME=trade-m8-assets
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret for user authentication
JWT_SECRET=your_very_long_random_secret_key_here_min_32_chars

# Session configuration
SESSION_SECRET=your_session_secret_key_here
SESSION_DURATION=86400  # 24 hours in seconds

# API Rate Limiting
RATE_LIMIT_WINDOW=60000  # 1 minute in ms
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================

# Risk Management Defaults
MAX_POSITION_SIZE=0.10  # 10% of portfolio
MAX_PORTFOLIO_EXPOSURE=0.95  # 95% max exposure
MAX_DRAWDOWN=0.10  # 10% max drawdown
EMERGENCY_STOP_LOSS=0.15  # 15% emergency stop

# AI Configuration
AI_WEIGHT=0.4  # 40% AI contribution to signals
AI_MIN_CONFIDENCE=0.85  # 85% minimum confidence
FUSION_THRESHOLD=0.8  # 80% fusion threshold
TARGET_WIN_RATE=90.0  # 90% target win rate

# Execution Configuration
DEFAULT_SLIPPAGE=0.01  # 1% slippage tolerance
GAS_PRICE_MULTIPLIER=1.2  # 20% gas buffer for DEX
ORDER_TIMEOUT=30000  # 30 seconds order timeout

# ============================================================================
# MONITORING & ALERTS
# ============================================================================

# Webhook URLs for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email alerts (SendGrid, Resend, etc.)
EMAIL_API_KEY=your_email_service_api_key
ALERT_EMAIL=your-email@example.com

# SMS alerts (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
ALERT_PHONE_NUMBER=+1234567890

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Environment
NODE_ENV=development  # development | production | test
LOG_LEVEL=info  # debug | info | warn | error

# Feature Flags
ENABLE_PAPER_TRADING=true
ENABLE_AI_ENHANCEMENT=true
ENABLE_MULTI_EXCHANGE=true
ENABLE_ARBITRAGE=true
ENABLE_BACKTESTING=true

# Debugging
DEBUG_MODE=false
VERBOSE_LOGGING=false
SAVE_TRADE_LOGS=true

# ============================================================================
# BACKTESTING CONFIGURATION
# ============================================================================

# Historical Data Sources
HISTORICAL_DATA_SOURCE=coingecko  # coingecko | cryptocompare | custom
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=10000

# ============================================================================
# NOTES
# ============================================================================

# 1. SECURITY: Never commit .env or .env.local files to Git!
# 2. For production, use Cloudflare Workers secrets:
#    wrangler secret put SECRET_NAME
# 3. Start with testnet/sandbox modes before going live
# 4. Use dedicated wallets with limited funds for trading
# 5. Regularly rotate API keys and secrets
# 6. Monitor API usage to avoid rate limits
# 7. Test thoroughly in paper trading mode first

# ============================================================================
# QUICK SETUP GUIDE
# ============================================================================

# 1. Copy this file:
#    cp .env.example .env.local

# 2. Fill in your API keys (start with free tiers)

# 3. For Binance testnet:
#    - Visit: https://testnet.binance.vision/
#    - Get testnet API keys (no real money)

# 4. For Coinbase sandbox:
#    - Visit: https://public.sandbox.pro.coinbase.com/
#    - Get sandbox API credentials

# 5. For DEX trading:
#    - Get Alchemy/Infura RPC endpoints
#    - Create a dedicated trading wallet
#    - Fund with small amounts for testing

# 6. Set Cloudflare secrets:
#    wrangler secret put BINANCE_API_KEY
#    wrangler secret put BINANCE_SECRET_KEY
#    wrangler secret put COINBASE_API_KEY
#    # ... etc for sensitive keys

# 7. Test configuration:
#    npm run test:config
