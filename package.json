{
  "name": "xq-trade-m8-cloudflare",
  "version": "1.0.0",
  "description": "XQ Trade M8 - Production Automated Trading Platform for Cloudflare",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist --project-name=trade-m8-live-app",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "deploy:all": "npm run build && npm run deploy && npm run deploy:worker",
    "deploy:full": "bash scripts/deploy-cloudflare.sh",
    "db:migrate": "node scripts/migrate-database.js",
    "test": "vitest",
    "test:production": "bash scripts/test-production.sh",
    "test:e2e": "bash scripts/post-deploy-verify.sh",
    "health": "bash scripts/health-monitor.sh https://trade-m8.app once",
    "health:monitor": "bash scripts/health-monitor.sh https://trade-m8.app 300",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^1.4.2",
    "@types/bun": "^1.3.14",
    "axios": "^1.18.0",
    "ccxt": "^4.5.59",
    "date-fns": "^3.6.0",
    "ethers": "^6.17.0",
    "lucide-react": "^0.294.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.15.4",
    "web3": "^4.16.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "wrangler": "^4.102.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "trading",
    "automated",
    "crypto",
    "forex",
    "cloudflare",
    "workers",
    "ai",
    "ml"
  ],
  "author": "XQ Trade M8",
  "license": "MIT"
}
